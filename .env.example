# Portal AM Imóveis — variáveis de ambiente
# Copie para `.env` (que é gitignored) e preencha com valores REAIS.
#   cp .env.example .env && chmod 600 .env
#
# Gere segredos fortes com:
#   python -c "import secrets; print(secrets.token_hex(32))"

# Segredo de assinatura do JWT (HS256). OBRIGATÓRIO em produção.
# Se não definido, a app gera um aleatório por processo -> tokens quebram entre workers/restarts.
JWT_SECRET=troque-por-um-hex-de-64-caracteres

# Senha do admin criado no seed inicial (só usada se ainda NÃO existir nenhum admin).
# Para trocar a senha de um admin já existente, use a tela /usuarios ou PUT /api/v1/usuarios/{id}.
ADMIN_PASSWORD=defina-uma-senha-forte

# Senha do Postgres. Usada pelo serviço `db` e pela DATABASE_URL do serviço `portal`.
POSTGRES_PASSWORD=defina-uma-senha-forte

# Conexão do app com o banco (o host DEVE ser habitacao_db — não use `db`, é VIP do Swarm).
DATABASE_URL=postgresql://habitacao:${POSTGRES_PASSWORD}@habitacao_db:5432/habitacao

# --- WhatsApp (uazapi) -------------------------------------------------------
# URL PÚBLICA do portal. É com ela que montamos a URL do webhook registrada na uazapi.
# A uazapi é um serviço REMOTO: em dev ela NÃO alcança localhost — use um túnel
# (ngrok/cloudflared) e ponha a URL dele aqui, senão nenhuma mensagem chega.
APP_PUBLIC_URL=https://portal.amimoveis.tec.br

# production | development. Em `production` o guard de SSRF EXIGE https nas URLs externas.
APP_ENV=production

# NÃO existe UAZAPI_WEBHOOK_SECRET aqui de propósito: o segredo do webhook é gerado por
# integração e vive em chat_integracoes.webhook_secret. Assim ele acompanha a instância e
# rotacioná-lo não exige redeploy.
